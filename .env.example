# ─────────────────────────────────────────────────────────────
# CLIENT-SIDE (safe to expose — must use the VITE_ prefix)
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-supabase-anon-key>
VITE_SUPABASE_PROJECT_ID=<your-project-ref>

# Stripe — PUBLISHABLE key only on the client.
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# ─────────────────────────────────────────────────────────────
# SERVER-SIDE ONLY — do NOT put these here or use the VITE_ prefix.
# Set them as Supabase Edge Function secrets instead:
#   supabase secrets set STRIPE_SECRET_KEY=...
#   supabase secrets set STRIPE_WEBHOOK_SECRET=...
#   supabase secrets set RESEND_API_KEY=...
#   supabase secrets set OWNER_EMAIL=...
#   supabase secrets set SITE_URL=...
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...
# ─────────────────────────────────────────────────────────────
